# Application
APP_NAME=envprism
APP_ENV=development
PORT=3000

# Database
DATABASE_URL="postgres://user:pass@localhost:5432/db"
DATABASE_POOL_SIZE=10

# Secrets
SECRET_KEY='do-not-share'
API_TOKEN="abc 123" # set per environment

# Edge cases
EMPTY=
QUOTED_EMPTY=""
WITH_HASH="value#not#comment"
export EXPORTED_VAR=visible

# trailing comment with no kv after
