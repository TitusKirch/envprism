{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "envprism",
  "version": "0.2.0",
  "description": "TUI-based env file manager — refract one set of variables into many environment views.",
  "keywords": [
    "bun",
    "cli",
    "commitlint",
    "conventional-commits",
    "dependabot",
    "dotenv",
    "env",
    "husky",
    "kirchdev",
    "opentui",
    "oxfmt",
    "oxlint",
    "pnpm",
    "release-please",
    "tui"
  ],
  "homepage": "https://github.com/TitusKirch/envprism#readme",
  "bugs": {
    "url": "https://github.com/TitusKirch/envprism/issues"
  },
  "license": "MIT",
  "author": "Titus Kirch <titus.kirch@kirch.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TitusKirch/envprism.git"
  },
  "bin": {
    "envprism": "./dist/bin/envprism.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config/define.d.ts",
      "import": "./dist/config/define.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix --deny-warnings",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "check": "pnpm lint && pnpm format && pnpm typecheck",
    "check:fix": "pnpm lint:fix && pnpm format:fix",
    "taze": "taze",
    "taze:w": "taze -w",
    "prepare": "husky",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@opentui/core": "^0.2.15",
    "c12": "^3.0.0",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "defu": "^6.1.4",
    "pathe": "^2.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "taze": "^19.13.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "packageManager": "pnpm@11.2.2"
}
