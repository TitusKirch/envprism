# =============================================================================
# Application
# =============================================================================
APP_NAME=envprism
APP_ENV=development
APP_URL=http://localhost:3001
PORT=3001
LOG_LEVEL=debug
TZ=Europe/Berlin

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgres://localhost:5432/envprism_dev
DATABASE_POOL_SIZE=5
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379
REDIS_DB=1

# =============================================================================
# Auth / Secrets
# =============================================================================
SECRET_KEY=dev-secret-do-not-ship
API_TOKEN=dev_local_token_abcdef1234567890
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBA...dev...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjAN...dev...\n-----END PUBLIC KEY-----"
OAUTH_CLIENT_ID=dev-client-id
OAUTH_CLIENT_SECRET=dev-client-secret
SESSION_TIMEOUT=86400

# =============================================================================
# External services
# =============================================================================
SENTRY_DSN=
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=
SLACK_WEBHOOK_URL=
S3_BUCKET=envprism-assets-dev
S3_REGION=eu-central-1

# =============================================================================
# Feature flags
# =============================================================================
FEATURE_NEW_UI=true
FEATURE_BETA_EXPORT=true
FEATURE_TELEMETRY=false
FEATURE_DARK_MODE=true
FEATURE_AI_SUGGEST=true
FEATURE_AUDIT_LOG=false
FEATURE_RATE_LIMIT=false
FEATURE_RBAC=false
FEATURE_SSO=false
FEATURE_WEBHOOKS=true
DEBUG=true
DEV_FAST_REFRESH=true

# =============================================================================
# Mailer
# =============================================================================
MAIL_FROM=dev@envprism.local
MAIL_REPLY_TO=dev@envprism.local
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=none

# =============================================================================
# Queue / workers
# =============================================================================
QUEUE_CONNECTION=sync
QUEUE_DEFAULT=default
WORKER_CONCURRENCY=1
WORKER_TIMEOUT=60
WORKER_MEMORY_LIMIT=256

# =============================================================================
# Cache
# =============================================================================
CACHE_DRIVER=memory
CACHE_PREFIX=envprism_dev
CACHE_TTL_SECONDS=60

# =============================================================================
# Storage
# =============================================================================
STORAGE_DRIVER=local
STORAGE_ROOT=./tmp/storage
STORAGE_MAX_UPLOAD_MB=200

# =============================================================================
# Observability
# =============================================================================
OTEL_SERVICE_NAME=envprism-dev
METRICS_PORT=9090
TRACING_SAMPLE_RATE=1.0
HEALTHCHECK_PATH=/healthz

# =============================================================================
# Limits
# =============================================================================
RATE_LIMIT_PER_MINUTE=100000
RATE_LIMIT_BURST=1000
MAX_REQUEST_SIZE_MB=100
REQUEST_TIMEOUT_MS=120000

# =============================================================================
# Integrations
# =============================================================================
GITHUB_APP_ID=12345
GITHUB_CLIENT_ID=Iv1.devdevdevdevdev
GITHUB_CLIENT_SECRET=ghs_dev_xxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_BOT_TOKEN=xoxb-dev-xxxxxxxxxxx-xxxxxxxxxxx
SLACK_SIGNING_SECRET=devsigningsecret
LINEAR_API_KEY=lin_api_dev_xxxxxxxx

# =============================================================================
# Misc
# =============================================================================
SUPPORT_EMAIL=dev@envprism.local
BRAND_PRIMARY_COLOR=#ff6b6b
SESSION_COOKIE_NAME=envprism_dev_sid
EXTRA_DEV_FLAG=on
