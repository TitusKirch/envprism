# =============================================================================
# Application
# =============================================================================
APP_NAME=envprism
APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=info
TZ=UTC

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgres://localhost:5432/envprism
DATABASE_POOL_SIZE=10
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# =============================================================================
# Auth / Secrets — fill in per environment
# =============================================================================
SECRET_KEY=
API_TOKEN=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
SESSION_TIMEOUT=3600

# =============================================================================
# External services
# =============================================================================
SENTRY_DSN=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
SENDGRID_API_KEY=
SLACK_WEBHOOK_URL=
S3_BUCKET=envprism-assets
S3_REGION=eu-central-1

# =============================================================================
# Feature flags
# =============================================================================
FEATURE_NEW_UI=false
FEATURE_BETA_EXPORT=false
FEATURE_TELEMETRY=true
FEATURE_DARK_MODE=true
FEATURE_AI_SUGGEST=false
FEATURE_AUDIT_LOG=false
FEATURE_RATE_LIMIT=true
FEATURE_RBAC=true
FEATURE_SSO=false
FEATURE_WEBHOOKS=true

# =============================================================================
# Mailer
# =============================================================================
MAIL_FROM=noreply@envprism.app
MAIL_REPLY_TO=hello@envprism.app
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# =============================================================================
# Queue / workers
# =============================================================================
QUEUE_CONNECTION=redis
QUEUE_DEFAULT=default
QUEUE_RETRY_AFTER=90
WORKER_CONCURRENCY=4
WORKER_TIMEOUT=120
WORKER_MEMORY_LIMIT=512

# =============================================================================
# Cache
# =============================================================================
CACHE_DRIVER=redis
CACHE_PREFIX=envprism
CACHE_TTL_SECONDS=3600
CACHE_LOCK_DRIVER=redis

# =============================================================================
# Storage
# =============================================================================
STORAGE_DRIVER=s3
STORAGE_ROOT=/var/data/envprism
STORAGE_PUBLIC_URL=https://cdn.envprism.app
STORAGE_MAX_UPLOAD_MB=25

# =============================================================================
# Observability
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=envprism
METRICS_PORT=9090
TRACING_SAMPLE_RATE=0.1
HEALTHCHECK_PATH=/healthz
READINESS_PATH=/readyz

# =============================================================================
# Limits
# =============================================================================
RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_BURST=20
MAX_REQUEST_SIZE_MB=10
MAX_CONCURRENT_REQUESTS=200
REQUEST_TIMEOUT_MS=30000

# =============================================================================
# Integrations
# =============================================================================
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
ANALYTICS_WRITE_KEY=
LINEAR_API_KEY=

# =============================================================================
# Misc
# =============================================================================
SUPPORT_EMAIL=support@envprism.app
PRIVACY_POLICY_URL=https://envprism.app/privacy
TERMS_URL=https://envprism.app/terms
BRAND_PRIMARY_COLOR=#82aaff
SESSION_COOKIE_NAME=envprism_sid
