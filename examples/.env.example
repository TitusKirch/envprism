# =============================================================================
# Application
# =============================================================================
APP_NAME=envprism
APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=info
TZ=UTC

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgres://localhost:5432/envprism
DATABASE_POOL_SIZE=10
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# =============================================================================
# Auth / Secrets — fill in per environment
# =============================================================================
SECRET_KEY=
API_TOKEN=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
SESSION_TIMEOUT=3600

# =============================================================================
# External services
# =============================================================================
SENTRY_DSN=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
SENDGRID_API_KEY=
SLACK_WEBHOOK_URL=
S3_BUCKET=envprism-assets
S3_REGION=eu-central-1

# =============================================================================
# Feature flags
# =============================================================================
FEATURE_NEW_UI=false
FEATURE_BETA_EXPORT=false
FEATURE_TELEMETRY=true
FEATURE_DARK_MODE=true
